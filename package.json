{
  "name": "emoji-buster-backend",
  "version": "1.0.0",
  "description": "Backend system for Emoji Buster game with user authentication and leaderboard",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "test": "node test-api.js",
    "sample-data": "node sample-data.js",
    "deploy": "chmod +x deploy.sh && ./deploy.sh",
    "pm2:start": "pm2 start ecosystem.config.js",
    "pm2:stop": "pm2 stop emoji-buster-backend",
    "pm2:restart": "pm2 restart emoji-buster-backend"
  },
  "keywords": [
    "game",
    "leaderboard",
    "authentication",
    "emoji-buster"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "joi": "^17.9.2",
    "jsonwebtoken": "^9.0.2",
    "node-fetch": "^2.7.0",
    "sqlite3": "^5.1.6"
  },
  "devDependencies": {
    "jest": "^29.6.2",
    "nodemon": "^3.0.1",
    "supertest": "^6.3.3"
  },
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=8.0.0"
  }
}
